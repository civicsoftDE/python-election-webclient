<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>{% block title %}{% endblock %}</title>

    <link rel="stylesheet" href="qrc:///static/css/bootstrap.min.css">
    <link rel="stylesheet" href="qrc:///static/css/style.css">
    <link rel="stylesheet" href="qrc:///static/fonts/bootstrap-icons.min.css">
    <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/choices.js@11.1.0/public/assets/styles/choices.min.css"
    />

</head>
<body>
<section id="header" class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center">
            {% block header %}
                <button type="button" class="btn btn-primary me-2" onclick="loadView('start')"><i
                        class="bi bi-house"></i></button>{% endblock %}
            <h1 class="h3 fw-normal text-secondary mb-0">{% block page_title %}Startseite{% endblock %}</h1>
        </div>
        <div class="d-flex align-items-center">
            <div class="text-primary">
                {% if not app.user %}
                    Offline
                {% else %}
                    <div class="d-flex justify-content-end small text-end text-secondary">
                        <i class="bi bi-pin-map me-1"></i>{{ app.user.serial }}
                    </div>
                    {{ app.user.label }}
                {% endif %}
            </div>
            <button type="button" class="btn btn-light ms-3"><i class="bi bi-box-arrow-right"></i></button>
        </div>

    </div>
</section>

<section class="container-fluid">
    {% block message %}
        {% for flash in app.flash_messages %}
            <div class="alert alert-{{ flash.type }}">
                {{ flash.message }}
            </div>
        {% endfor %}
    {% endblock %}
</section>
<main>{% block content %}{% endblock %}</main>


<footer class="bg-light container-fluid">
    <div class="row">
        <div class="col-12 text-center py-2 small text-muted">
            &copy;2026 - Benjamin Wagner
        </div>
    </div>
</footer>
<script type="text/javascript" src="qrc:///qtwebchannel/qwebchannel.js"></script>
<script src="qrc:///static/js/bootstrap.bundle.min.js"></script>
<script src="qrc:///static/js/app.js"></script>
<script src="https://cdn.jsdelivr.net/npm/choices.js@11.1.0/public/assets/scripts/choices.min.js"></script>
{% block extra_scripts %}{% endblock %}
</body>
</html>